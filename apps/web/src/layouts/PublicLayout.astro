---
import { appName } from '@debugpath/contracts';

import '../styles/global.css';

const { title = appName } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <main class="shell">
      <nav>
        <div class="nav-brand">
          <strong>{appName}</strong>
          <span class="nav-subtle">debugpath.dev</span>
        </div>
        <ul>
          <li><a href="/">Overview</a></li>
          <li><a href="/login">Sign in</a></li>
          <li><a href="/app">Investigation shell</a></li>
        </ul>
      </nav>
      <slot />
      <footer>
        Astro owns routes and layouts. Vue stays out until a workflow proves the extra client-side
        state is worth it.
      </footer>
    </main>
  </body>
</html>
