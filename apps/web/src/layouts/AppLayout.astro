---
import { appName } from '@debugpath/contracts';

import '../styles/global.css';

const {
  title = `${appName} workspace`,
  currentUser = null,
  currentWorkspace = null,
  redirectAfterLogout = '/login?logged_out=1',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <main class="shell page-grid">
      <nav>
        <div class="nav-brand">
          <strong>{appName}</strong>
          <span class="nav-subtle">{currentWorkspace?.name ?? 'Workspace shell'}</span>
        </div>
        <ul>
          <li><a href="/app">Investigations</a></li>
          <li><a href="/">Public overview</a></li>
          <li>
            <form action="/api/v1/auth/logout" method="post" class="inline-form">
              <input type="hidden" name="redirectTo" value={redirectAfterLogout} />
              <button class="button-link button-reset" type="submit">Log out</button>
            </form>
          </li>
        </ul>
      </nav>

      {currentUser && currentWorkspace && (
        <section class="toolbar">
          <div>
            <span class="label">Signed in</span>
            <strong>{currentUser.displayName ?? currentUser.email}</strong>
          </div>
          <div>
            <span class="label">Workspace</span>
            <strong>{currentWorkspace.slug}</strong>
          </div>
        </section>
      )}

      <slot />
      <footer>
        This route stays Astro-owned. Interactive islands only enter when timeline filters,
        inspectors, or bundle selection become awkward without them.
      </footer>
    </main>
  </body>
</html>
